---
import { SITE_TITLE, siteConfig } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Ana Sayfa</HeaderLink>
			<HeaderLink href="/blog">Yazılar</HeaderLink>
			<HeaderLink href="/okuma-haritasi">Okuma Haritası</HeaderLink>
			<HeaderLink href="/about">Hakkında</HeaderLink>
		</div>
		<div class="nav-actions">
			<a
				class="social-icon-link"
				href={siteConfig.social.youtube}
				aria-label="Derin Okuma YouTube"
				title="YouTube"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4L15.8 12l-6.2 3.6Z"
					/>
				</svg>
			</a>
			<a
				class="social-icon-link"
				href={siteConfig.social.tiktok}
				aria-label="Derin Okuma TikTok"
				title="TikTok"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M19.6 6.7a4.8 4.8 0 0 1-3.8-4.3V2h-3.4v13.7a2.9 2.9 0 1 1-2.9-3.3c.3 0 .5 0 .8.1V9a6.4 6.4 0 0 0-.8-.1 6.3 6.3 0 1 0 6.3 6.3V8.7a8.2 8.2 0 0 0 4.8 1.5V6.8c-.3 0-.7 0-1-.1Z"
					/>
				</svg>
			</a>
			<button id="theme-toggle" aria-label="Temayı değiştir" title="Temayı değiştir">
				<span id="theme-icon">🌙</span>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(function () {
		function updateIcon() {
			const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
			const icon = document.getElementById('theme-icon');
			if (icon) icon.textContent = isDark ? '☀️' : '🌙';
		}
		updateIcon();
		const btn = document.getElementById('theme-toggle');
		if (btn) {
			btn.addEventListener('click', function () {
				const current = document.documentElement.getAttribute('data-theme');
				const next = current === 'dark' ? 'light' : 'dark';
				document.documentElement.setAttribute('data-theme', next);
				localStorage.setItem('theme', next);
				updateIcon();
			});
		}
	})();
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg-header, white);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: background-color 0.2s;
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
	}

	.internal-links {
		display: flex;
		gap: 20px;
		align-items: center;
	}

	.internal-links a,
	h2 a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	.internal-links a.active,
	h2 a.active {
		text-decoration: none;
		border-bottom-color: var(--color-accent);
	}

	nav a:hover {
		color: var(--color-accent);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.social-icon-link,
	#theme-toggle {
		display: inline-flex;
		width: 36px;
		height: 36px;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		color: rgb(var(--black));
		cursor: pointer;
		border-radius: 6px;
		line-height: 1;
		padding: 0;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}

	.social-icon-link svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	#theme-toggle {
		font-size: 1.2rem;
	}

	.social-icon-link:hover,
	#theme-toggle:hover {
		background: rgba(var(--gray-light), 0.4);
	}

	.social-icon-link:focus-visible,
	#theme-toggle:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	@media (max-width: 768px) {
		header {
			padding: 0.75em 1em;
		}

		nav {
			flex-direction: column;
			align-items: flex-start;
			justify-content: flex-start;
			gap: 10px;
		}

		h2 {
			font-size: 1.6em;
			line-height: 1.1;
			max-width: calc(100% - 132px);
		}

		.internal-links {
			width: 100%;
			display: flex;
			justify-content: flex-start;
			gap: 20px;
			flex-wrap: wrap;
		}

		.internal-links a {
			padding: 0.4em 0;
			font-size: 1rem;
		}

		.nav-actions {
			position: absolute;
			top: 1rem;
			right: 1rem;
		}
	}
</style>
