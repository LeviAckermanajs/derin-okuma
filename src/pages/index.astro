---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Derinlemesine metin okumaları</p>
				<h1>Derin Okuma</h1>
				<p class="hero-text">Hakikati anlamak için metinlerin yüzeyinde değil, derininde dolaşan okumalar.</p>
				<p class="hero-description">
					Risale-i Nur, Kur’an ve insan üzerine yapılan derin metin analizleri
					ve düşünce incelemeleri.
				</p>
				<a class="hero-button" href="/blog">Yazıları Oku →</a>
			</section>

			<section class="home-section">
				<h2>Son Yazılar</h2>

				<div class="post-list">
					{posts.map((post) => (
						<a class="post-card" href={`/blog/${post.slug}`}>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
							<p class="post-date">
								{post.data.pubDate.toLocaleDateString('tr-TR')}
							</p>
						</a>
					))}
				</div>
			</section>

			<section class="home-section">
				<h2>Bu site ne sunuyor?</h2>
				<div class="info-box">
					<p>
						Bu site, metinleri sadece özetlemek için değil; ince mesajlarını,
						kavram katmanlarını ve insanla kurduğu bağı anlamak için oluşturuldu.
					</p>
					<p>
						Burada Risale-i Nur analizleri, Kur’an üzerine düşünce yazıları ve
						insan anlam arayışına dair metinler yer alacak.
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>