---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Terms of Service — Derin Okuma" description="Terms of Service for Derin Okuma" />
	</head>
	<body>
		<Header />

		<main class="about-page">
			<section class="about-hero">
				<p class="about-eyebrow">Legal</p>
				<h1>Terms of Service</h1>
				<p class="about-lead">
					Please read these terms carefully before using Derin Okuma.
				</p>
			</section>

			<section class="about-section">
				<h2>About This Service</h2>
				<p>
					Derin Okuma (<strong>derin-okuma.vercel.app</strong>) is a creator-operated educational
					and reflection content website. It publishes layered readings of texts — primarily
					from the Risale-i Nur collection — to support thoughtful engagement with Islamic
					scholarly works.
				</p>
				<p>
					As part of its publishing workflow, Derin Okuma uses an internal tool that connects
					to the TikTok API to prepare and upload short-form videos as drafts on behalf of
					the site's creator. This tool is used solely by the site operator and is not a
					public application open to general users.
				</p>
			</section>

			<section class="about-section">
				<h2>Acceptable Use</h2>
				<p>
					By accessing this website or using any associated tools, you agree to the following:
				</p>
				<ul>
					<li>You will not use this service for any illegal, harmful, or infringing purpose.</li>
					<li>You will comply with TikTok's Terms of Service and Community Guidelines when
					interacting with any TikTok-connected features.</li>
					<li>You will not attempt to reverse-engineer, misuse, or abuse any API integrations
					or credentials associated with this project.</li>
					<li>You will not upload content that violates platform rules, intellectual property
					rights, or applicable law.</li>
				</ul>
			</section>

			<section class="about-section">
				<h2>Creator Responsibility</h2>
				<p>
					The site operator (creator) retains full responsibility for reviewing and publishing
					all content. Videos uploaded via the TikTok integration are created as drafts and
					must be manually reviewed and approved by the creator before they are published.
					The creator is responsible for ensuring all content complies with applicable laws
					and platform policies.
				</p>
			</section>

			<section class="about-section">
				<h2>Limitation of Liability</h2>
				<p>
					This service is provided "as is" without warranties of any kind. The creator is not
					liable for any damages arising from the use or inability to use this website or
					its associated tools.
				</p>
			</section>

			<section class="about-section">
				<h2>Changes to These Terms</h2>
				<p>
					These terms may be updated from time to time. Continued use of the site after
					changes are posted constitutes acceptance of the updated terms.
				</p>
			</section>

			<section class="about-section">
				<h2>Contact</h2>
				<p>
					For questions about these Terms of Service, please contact:
					<a href="mailto:derinokumaofficial@gmail.com">derinokumaofficial@gmail.com</a>
				</p>
			</section>

			<section class="about-note">
				<p>Last updated: May 2026</p>
			</section>
		</main>

		<Footer />
	</body>
</html>
