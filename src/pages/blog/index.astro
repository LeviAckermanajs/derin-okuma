---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Yazılar | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Tüm içerikler</p>
				<h1>Yazılar</h1>
				<p class="hero-description">
					Risale-i Nur, Kur’an ve insan üzerine yayınlanan tüm yazılar burada yer alır.
				</p>
			</section>

			<section class="home-section">
				<div class="post-list">
					{posts.map((post) => (
						<a class="post-card" href={`/blog/${post.id}`}>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
							<p class="post-date">
								{post.data.pubDate.toLocaleDateString('tr-TR')}
							</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>