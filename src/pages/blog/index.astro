---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function extractSeries(title: string): string {
	const dashIndex = title.indexOf(' - ');
	if (dashIndex === -1) return 'Diğer';
	return title.substring(0, dashIndex);
}

const grouped = posts.reduce((acc, post) => {
	const series = extractSeries(post.data.title);
	if (!acc[series]) acc[series] = [];
	acc[series].push(post);
	return acc;
}, {} as Record<string, typeof posts>);

const seriesOrder = Object.keys(grouped).sort((a, b) => {
	if (a === 'Diğer') return 1;
	if (b === 'Diğer') return -1;
	return a.localeCompare(b, 'tr');
});
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Yazılar | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Tüm içerikler</p>
				<h1>Yazılar</h1>
				<p class="hero-description">
					Risale-i Nur, Kur'an ve insan üzerine yayınlanan tüm yazılar burada yer alır.
				</p>
			</section>

			<section class="home-section">
				{seriesOrder.map((series) => (
					<div class="series-group">
						<h2 class="series-title">{series}</h2>
						<div class="post-list">
							{grouped[series].map((post) => (
								<a class="post-card" href={`/blog/${post.id}`}>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
									<p class="post-date">
										{post.data.pubDate.toLocaleDateString('tr-TR')}
									</p>
								</a>
							))}
						</div>
					</div>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.series-group {
		margin-bottom: 2.5em;
	}
	.series-title {
		font-size: 1.1em;
		font-weight: 700;
		color: rgb(var(--gray));
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border-bottom: 2px solid rgb(var(--gray-light));
		padding-bottom: 0.4em;
		margin-bottom: 1em;
	}
</style>
